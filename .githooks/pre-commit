#!/usr/bin/env bash
set -e
if ! command -v gitleaks &>/dev/null; then
  echo "[pre-commit] gitleaks is required for the secret-scan hook." >&2
  echo "[pre-commit] Install gitleaks or unset core.hooksPath before committing." >&2
  exit 1
fi
gitleaks protect --staged --redact --no-banner --config .gitleaks.toml
