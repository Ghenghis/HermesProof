# HermesProof environment variables — NAMES ONLY.
# Copy this to your secret store at G:\private\.env (NEVER inside any repo).
# .gitleaks.toml + .gitignore prevent accidental commits of populated values.

# === HermesProof core ===
# HERMES3D_ENV_FILE=<absolute path to your .env, default G:\private\.env>
# HERMES3D_PROFILE=vps    # set to 'vps' to use HERMES3D_VPS_ENV_FILE
# HERMES3D_VPS_ENV_FILE=<path to deploy-time env, e.g. C:\Users\Admin\Downloads\VPS\.env>
# MCP_LOCK_WORKSPACE=<workspace root override>
# MCP_LOCK_STATE_DIR=<state dir name override>

# === Hermes Agent bridge (USER-as-Hermes-Agent delegation) ===
# Disabled by default. Set HERMES_AGENT_ENABLED=1 to activate.
# HERMES_AGENT_ENABLED=1
# HERMES_AGENT_PROJECT_GOALS=<paragraph describing project; agent reasons against this>
# HERMES_AGENT_SCOPE=merge_pr,close_blocked,grant_minor_enhancement
# HERMES_AGENT_FAILOVER=deepseek,minimax,siliconflow,lm_studio,ollama,hipfire

# === Cloud reasoning providers (preferred order: DeepSeek → MiniMax → SiliconFlow) ===
# Values live in G:\private\.env, NEVER in any committed file.
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# MINIMAX_API_KEY=
# MINIMAX_MODEL=                         # MiniMax highspeed 2.1-2.7 series id
# SILICONFLOW_API_KEY=
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V2.5

# === Local providers (no API keys; URLs only) ===
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LMSTUDIO_MODEL=NousResearch/Hermes-4-14B-FP8
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:14b
# HIPFIRE_BASE_URL=                      # AMD GPU node URL when available
# HIPFIRE_MODEL=NousResearch/Hermes-4-14B-FP8

# === GitHub / review ===
# GITHUB_TOKEN=
# CODERABBIT_API_KEY=

# === Voice / speech (Hermes3D launcher) ===
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=

# === Model retrieval ===
# HUGGINGFACE_TOKEN=
